DATABASE_URL=
PORT=5000
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Google Drive — OAuth user delegation
# 1. In Google Cloud Console, create an OAuth 2.0 Client ID (Application type:
#    Desktop app) and download its JSON. Point this var at that file.
GOOGLE_OAUTH_CLIENT_SECRET_PATH="E:\PROJECTS\CrowdSync 2.0\credential\client_secret.json"
# 2. Run `node scripts/oauth-init.js` once. A browser opens, you grant Drive
#    access, and the resulting refresh token is saved at this path.
GOOGLE_OAUTH_TOKEN_PATH="E:\PROJECTS\CrowdSync 2.0\credential\token.json"
# 3. ID of the Drive folder where per-student subfolders are created.
DRIVE_PARENT_FOLDER_ID=105iEicTEIstnNQ0BGf-xikTCvCCxeYBq

# Static API key the face-recognition tool sends as `X-API-Key` to mark
# attendance via POST /api/attendance/face. Generate any long random string.
FACE_SYSTEM_API_KEY=
