# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit credentials.

# Google Drive — OAuth user delegation. Use the SAME files that the backend
# is configured to use; the Python tool reads (doesn't write to) them.

# Path to client_secret.json downloaded from Google Cloud Console (Desktop app).
GOOGLE_OAUTH_CLIENT_SECRET_PATH=E:\PROJECTS\CrowdSync 2.0\credential\client_secret.json

# Path to token.json (created by `node scripts/oauth-init.js` in the backend).
GOOGLE_OAUTH_TOKEN_PATH=E:\PROJECTS\CrowdSync 2.0\credential\token.json

# ID of the Drive parent folder (NOT the folder name).
# Open the folder in Drive web; the ID is the long alphanumeric string in the URL,
# e.g. https://drive.google.com/drive/folders/1aB2cD3eFgHiJkLmNoPqRsTuVwXyZ
#                                              ^^^^^^^^^^^^^^^^^^^^^^^^^^ this part
DRIVE_PARENT_FOLDER_ID=
