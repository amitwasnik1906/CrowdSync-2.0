# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit credentials.

# Path to the Google service-account JSON key file.
# The same key the backend uses works here (read-only scope is enough for this tool).
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./credentials/service-account.json

# ID of the shared Drive parent folder (NOT the folder name).
# Open the folder in Drive web; the ID is the long alphanumeric string in the URL,
# e.g. https://drive.google.com/drive/folders/1aB2cD3eFgHiJkLmNoPqRsTuVwXyZ
#                                              ^^^^^^^^^^^^^^^^^^^^^^^^^^ this part
DRIVE_PARENT_FOLDER_ID=
